# 环境变量配置示例
# 复制此文件为 .env.local 并修改相应的值

# 后端 API 地址（默认使用线上 API）
NEXT_PUBLIC_BACKEND_URL=https://www.yusteven.com

# 开发模式标识（开发环境建议设置为 true）
NEXT_PUBLIC_DEV_MODE=true

# API 端点（一般不需要修改）
NEXT_PUBLIC_WEATHER_API=/api/weather/all
NEXT_PUBLIC_IMAGE_API=/api/image

# 可选：启用调试模式
# DEBUG=true

# ====================================
# 本地开发说明
# ====================================
# 1. 默认配置：使用线上 API，只需启动前端即可
#    npm run dev
#
# 2. 完全本地开发：需要启动本地后端服务
#    - 终端1: cd backend && node weather-server.js  # 端口 3001
#    - 终端2: cd backend && node s3-server.js       # 端口 3002
#    - 修改下方配置: NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
#    - 启动前端: npm run dev

