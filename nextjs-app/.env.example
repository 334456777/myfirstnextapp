# 环境变量配置示例
# 复制此文件为 .env.local 并修改相应的值

# ====================================
# ⚠️ 重要：API 代理配置（避免跨域问题）
# ====================================
# Next.js 通过 rewrites 自动代理 API 请求，避免跨域问题：
# - /api/weather/* → http://localhost:3001/api/weather/*
# - /api/image/* → http://localhost:3002/api/image/*
#
# 前端代码直接请求 /api/* 即可，Next.js 会自动处理代理！

# 后端 API 地址（保留配置，实际由 next.config.js 处理）
NEXT_PUBLIC_BACKEND_URL=https://www.yusteven.com

# 开发模式标识（已由 next.config.js 自动根据 NODE_ENV 设置，无需手动配置）
# - npm run dev → 自动启用开发模式（显示所有卡片）
# - npm start → 生产环境模式（检查日志文件后显示卡片）
# NEXT_PUBLIC_DEV_MODE=true

# API 端点（一般不需要修改）
NEXT_PUBLIC_WEATHER_API=/api/weather/all
NEXT_PUBLIC_IMAGE_API=/api/image

# 可选：启用调试模式
# DEBUG=true

# ====================================
# 本地开发说明
# ====================================
# 方式 1：使用线上 API（推荐，最简单）
#   npm run dev
#   ✅ 无需启动后端服务
#   ✅ API 请求通过 next.config.js 代理，无跨域问题
#
# 方式 2：完全本地开发（需要本地后端）
#   - 终端1: cd backend && node weather-server.js  # 端口 3001
#   - 终端2: cd backend && node s3-server.js       # 端口 3002
#   - 终端3: npm run dev
#   ✅ API 请求通过 next.config.js 代理到本地后端
#   ✅ 无跨域问题，无需修改环境变量

